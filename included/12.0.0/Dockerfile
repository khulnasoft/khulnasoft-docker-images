# WARNING: this file was autogenerated by generate-included-image.js
# using
#   npm run add:included -- 12.0.0 khulnasoft/browsers:node16.16.0-chrome107-ff107-edge
#
# build this image with command
#   docker build -t khulnasoft/included:12.0.0 .
#
FROM khulnasoft/browsers:node16.16.0-chrome107-ff107-edge

# avoid too many progress messages
# https://github.com/khulnasoft/khulnasoft/issues/1243
ENV CI=1 \
# disable shared memory X11 affecting Khulnasoft v4 and Chrome
# https://github.com/khulnasoft/khulnasoft-docker-images/issues/270
  QT_X11_NO_MITSHM=1 \
  _X11_NO_MITSHM=1 \
  _MITSHM=0 \
  # point Khulnasoft at the /root/cache no matter what user account is used
  # see https://on.khulnasoft.io/caching
  KHULNASOFT_CACHE_FOLDER=/root/.cache/Khulnasoft \
  # Allow projects to reference globally installed khulnasoft
  NODE_PATH=/usr/local/lib/node_modules

# CI_XBUILD is set when we are building a multi-arch build from x64 in CI.
# This is necessary so that local `./build.sh` usage still verifies `khulnasoft` on `arm64`.
ARG CI_XBUILD

# should be root user
RUN echo "whoami: $(whoami)" \
  && npm config -g set user $(whoami) \
  # command "id" should print:
  # uid=0(root) gid=0(root) groups=0(root)
  # which means the current user is root
  && id \
  && npm install -g typescript \
  && npm install -g "khulnasoft@12.0.0" \
  && (node -p "process.env.CI_XBUILD && process.arch === 'arm64' ? 'Skipping khulnasoft verify on arm64 due to SIGSEGV.' : process.exit(1)" \
    || (khulnasoft verify \
    # Khulnasoft cache and installed version
    # should be in the root user's home folder
    && khulnasoft cache path \
    && khulnasoft cache list \
    && khulnasoft info \
    && khulnasoft version)) \
  # give every user read access to the "/root" folder where the binary is cached
  # we really only need to worry about the top folder, fortunately
  && ls -la /root \
  && chmod 755 /root \
  # always grab the latest Yarn
  # otherwise the base image might have old versions
  # NPM does not need to be installed as it is already included with Node.
  && npm i -g yarn@latest \
  # Show where Node loads required modules from
  && node -p 'module.paths' \
  # should print Khulnasoft version
  # plus Electron and bundled Node versions
  && khulnasoft version \
  && echo  " node version:    $(node -v) \n" \
    "npm version:     $(npm -v) \n" \
    "yarn version:    $(yarn -v) \n" \
    "typescript version:  $(tsc -v) \n" \
    "debian version:  $(cat /etc/debian_version) \n" \
    "user:            $(whoami) \n" \
    "chrome:          $(google-chrome --version || true) \n" \
    "firefox:         $(firefox --version || true) \n"

ENTRYPOINT ["khulnasoft", "run"]
